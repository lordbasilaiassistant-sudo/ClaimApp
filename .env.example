# ClaimApp — Example environment file
# Copy to .env for local dev testing ONLY.
# The deployed GitHub Pages site NEVER reads .env — all keys are entered in the browser UI.
# .env is gitignored and must never be committed.

# Optional: custom Base RPC endpoint (otherwise defaults to https://mainnet.base.org)
BASE_RPC_URL=

# DEV-ONLY: pre-fill the wallet input during local testing.
# NEVER set this on a shared machine. NEVER commit this file with a real value.
# Leave blank for production — the UI will prompt for a key at runtime.
DEV_TEST_PRIVATE_KEY=
